<!DOCTYPE html>
<html lang="en">
<head>
    <%-include("partials/head.ejs")%>
</head>
<body>
    <a href="/" class="btn btn-secondary m-2">Back</a>
    <h1 class="text-center">Album</h1>

    <div class="container text-center mt-4">
        <h2 class="mb-3">
            <%=album.name%>
        </h2>

        <div class="d-flex flex-column align-items-center">
            <img src="<%=album.images[0].url%>" alt="<%=album.name%>" class="img-fluid mb-3"
                style="max-width: 300px;">

            <a href="<%=album.external_urls.spotify%>" class="btn btn-success" target="_blank">
                Spotify Page
            </a>
        </div>
    </div>
</body>
</html>